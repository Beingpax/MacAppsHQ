---
import Preload from '../components/Preload.astro';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Discover the best Mac apps curated just for you."
} = Astro.props;

// Define critical resources
const criticalResources = [
  { path: '/styles/critical.css', type: 'style' },
  { path: '/fonts/inter-var.woff2', type: 'font' }
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Umami Analytics -->
    <script 
      defer 
      src="https://cloud.umami.is/script.js" 
      data-website-id="064ad88f-bc1d-4e39-806b-6351ccc65756"
    ></script>

    <!-- Critical CSS -->
    <style is:inline>
      :root { --primary: #007AFF; --primary-light: #409CFF; }
      .dark { color-scheme: dark; }
      body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    </style>
    
    <!-- Link to external critical.css -->
    <link rel="stylesheet" href="/styles/critical.css" />

    <!-- Theme initialization script -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');
      })();
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900">
    <slot />
  </body>
</html>