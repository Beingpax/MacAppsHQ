---
import PageLayout from '../layouts/PageLayout.astro';

const seoTitle = "Analytics - Mac App Directory";
const seoDescription = "Real-time analytics and statistics for Mac App Directory.";
---

<PageLayout 
  title={seoTitle}
  description={seoDescription}
  type="website"
>
  <div class="prose dark:prose-invert max-w-none">
    <h1 class="text-4xl font-bold mb-8">Analytics Dashboard</h1>
    
    <div class="w-full h-[800px] bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden">
      <iframe 
        src="https://counter.dev/dashboard.html?user=beingpax&token=jimAsbCU4c4%3D"
        width="100%"
        height="100%"
        frameborder="0"
        class="w-full h-full"
      ></iframe>
    </div>
  </div>
</PageLayout> 